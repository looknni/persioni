> ## /etc/NetworkManager/NetworkManager.conf
```
[main]
plugins=ifupdown,keyfile
#dns=dnsmasq
#systemd-resolved=true
#rc-manager=resolvconf

[ifupdown]
managed=true

[device]
wifi.scan-rand-mac-address=yes

[connectivity]
uri=
interval=0
```
